generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  passwordHash String
  xp           Int      @default(0)
  level        Int      @default(1)
  skillLevel   String   @default("beginner")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  missionAttempts  MissionAttempt[]
  achievements     UserAchievement[]
  interviewSessions InterviewSession[]

  @@map("users")
}

model Mission {
  id            String  @id @default(cuid())
  slug          String  @unique
  title         String
  difficulty    Int     @default(1)
  estimatedTime String
  xpReward      Int
  order         Int
  description   String
  scenario      String
  objectives    String
  requirements  String
  components    String
  feedbackData  String
  learningPath  String  @default("foundations")
  skillLevel    String  @default("beginner")

  missionAttempts   MissionAttempt[]
  interviewSessions InterviewSession[]

  @@map("missions")
}

model MissionAttempt {
  id           String   @id @default(cuid())
  userId       String
  missionId    String
  score        Int      @default(0)
  xpEarned     Int      @default(0)
  completed    Boolean  @default(false)
  architecture String   @default("{}")
  metrics      String   @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@map("mission_attempts")
}

/// Interview simulation session — timed 45-min FAANG-style system design session
model InterviewSession {
  id              String    @id @default(cuid())
  userId          String
  missionId       String
  /// active | completed | abandoned
  status          String    @default("active")
  /// Allowed duration in minutes (default 45)
  durationMinutes Int       @default(45)
  startedAt       DateTime  @default(now())
  submittedAt     DateTime?
  /// JSON: array of { questionId, askedAt, userAnswer }
  followupLog     String    @default("[]")
  /// JSON: RubricScores { correctness, depth, tradeoffs, apiDesign, timeManagement }
  rubricScores    String    @default("{}")
  /// Overall score 0-100 computed from rubric
  totalScore      Int       @default(0)
  /// XP awarded for this session
  xpEarned        Int       @default(0)
  /// Snapshot of the architecture submitted at end
  finalArchitecture String  @default("{}")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@map("interview_sessions")
}

model Achievement {
  id          String @id @default(cuid())
  slug        String @unique
  title       String
  description String
  icon        String
  xpBonus     Int    @default(0)

  userAchievements UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

model MissionRubric {
  id          String   @id @default(cuid())
  missionSlug String
  version     String
  items       String
  status      String   @default("approved")
  createdAt   DateTime @default(now())

  @@unique([missionSlug, version])
  @@map("mission_rubrics")
}
