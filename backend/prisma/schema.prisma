generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  passwordHash String
  xp           Int      @default(0)
  level        Int      @default(1)
  /// beginner | intermediate | advanced — set on onboarding, auto-upgrades on performance
  skillLevel   String   @default("beginner")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  missionAttempts       MissionAttempt[]
  achievements          UserAchievement[]
  lldAttempts           LLDAttempt[]
  interviewSessions     InterviewSession[]
  spacedRepetitionItems SpacedRepetitionItem[]
  mistakePatterns       MistakePattern[]

  @@map("users")
}

model Mission {
  id            String  @id @default(cuid())
  slug          String  @unique
  title         String
  difficulty    Int     @default(1)
  estimatedTime String
  xpReward      Int
  order         Int
  description   String
  scenario      String
  objectives    String  // JSON array
  requirements  String  // JSON object
  components    String  // JSON object
  feedbackData  String  // JSON object
  /// Learning path slug: foundations | async-queues | high-read | real-time | consistency | scale-streaming
  learningPath  String  @default("foundations")
  /// Skill level gate: beginner | intermediate | advanced
  skillLevel    String  @default("beginner")
  /// Whether the LLD phase is enabled for this mission
  lldEnabled    Boolean @default(false)
  /// JSON: LLDContent — classes, apiEndpoints, dataSchema, keyEntities
  lldContent    String?
  /// JSON: ReferenceSolution — components, connections, keyInsights, tradeoffs, antiPatterns
  referenceSolution String?

  missionAttempts       MissionAttempt[]
  lldAttempts           LLDAttempt[]
  interviewSessions     InterviewSession[]
  spacedRepetitionItems SpacedRepetitionItem[]

  @@map("missions")
}

model MissionAttempt {
  id           String   @id @default(cuid())
  userId       String
  missionId    String
  score        Int      @default(0)
  xpEarned     Int      @default(0)
  completed    Boolean  @default(false)
  architecture String   @default("{}") // JSON - saved architecture
  metrics      String   @default("{}") // JSON - simulation metrics
  /// True once the user has opened the Compare panel for this attempt
  comparisonViewed Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@map("mission_attempts")
}

/// LLD Phase submission
model LLDAttempt {
  id           String   @id @default(cuid())
  userId       String
  missionId    String
  classDesign  String   @default("")
  apiContracts String   @default("")
  dataSchema   String   @default("")
  score        Int      @default(0)
  feedback     String   @default("[]")
  xpEarned     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@map("lld_attempts")
}

/// Interview simulation session
model InterviewSession {
  id              String    @id @default(cuid())
  userId          String
  missionId       String
  status          String    @default("active")
  durationMinutes Int       @default(45)
  startedAt       DateTime  @default(now())
  submittedAt     DateTime?
  followupLog     String    @default("[]")
  rubricScores    String    @default("{}")
  totalScore      Int       @default(0)
  xpEarned        Int       @default(0)
  finalArchitecture String  @default("{}")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@map("interview_sessions")
}

model Achievement {
  id          String @id @default(cuid())
  slug        String @unique
  title       String
  description String
  icon        String
  xpBonus     Int    @default(0)

  userAchievements UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

/// One approved rubric per mission version.
model MissionRubric {
  id          String   @id @default(cuid())
  missionSlug String
  version     String
  items       String
  status      String   @default("approved")
  createdAt   DateTime @default(now())

  @@unique([missionSlug, version])
  @@map("mission_rubrics")
}

// ── Sprint 2: Spaced Repetition — F-005 ────────────────────────────────────────

/// SM-2 spaced repetition queue item per user/mission pair.
/// Created when score <80; graduated when user scores >=80 on re-attempt.
model SpacedRepetitionItem {
  id           String   @id @default(cuid())
  userId       String
  missionId    String
  /// SM-2 interval in days until next review
  interval     Int      @default(1)
  /// Number of consecutive successful recalls (quality >= 3)
  repetition   Int      @default(0)
  /// SM-2 ease factor — default 2.5, min 1.3
  easeFactor   Float    @default(2.5)
  /// When this item next appears in the review queue
  nextReviewAt DateTime @default(now())
  /// Score from the attempt that triggered this SR entry
  lastScore    Int      @default(0)
  /// Number of times the user has snoozed this item
  snoozeCount  Int      @default(0)
  /// true = scored >=80 on a re-attempt — removed from active queue
  graduated    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@unique([userId, missionId])
  @@map("spaced_repetition_items")
}

// ── Sprint 2: Mistake Patterns — F-003 ──────────────────────────────────────────

/// Recurring design anti-pattern detected from a user's mission history.
/// Refreshed within 60s of each submission; resolved when absent from last 3 missions.
model MistakePattern {
  id               String   @id @default(cuid())
  userId           String
  /// scalability | consistency | reliability | api-design | data-modelling
  dimension        String
  /// Unique pattern identifier slug
  patternSlug      String
  patternName      String
  /// How many times this pattern has been detected in completed submissions
  frequency        Int      @default(1)
  /// JSON array of mission slugs where this pattern was detected
  affectedMissions String   @default("[]")
  /// Concept card slug for remediation (links to On-Demand Concept Advisor)
  conceptSlug      String?
  /// True when pattern has not appeared in the last 3 completed missions
  isResolved       Boolean  @default(false)
  lastSeenAt       DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, patternSlug])
  @@map("mistake_patterns")
}
