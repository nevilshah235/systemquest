generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  passwordHash String
  xp           Int      @default(0)
  level        Int      @default(1)
  skillLevel   String   @default("beginner")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  missionAttempts MissionAttempt[]
  achievements    UserAchievement[]
  lldAttempts     LLDAttempt[]

  @@map("users")
}

model Mission {
  id            String  @id @default(cuid())
  slug          String  @unique
  title         String
  difficulty    Int     @default(1)
  estimatedTime String
  xpReward      Int
  order         Int
  description   String
  scenario      String
  objectives    String
  requirements  String
  components    String
  feedbackData  String
  learningPath  String  @default("foundations")
  skillLevel    String  @default("beginner")
  /// Whether the LLD phase is enabled for this mission
  lldEnabled    Boolean @default(false)
  /// JSON: LLDContent — classes, apiEndpoints, dataSchema, keyEntities
  lldContent    String?

  missionAttempts MissionAttempt[]
  lldAttempts     LLDAttempt[]

  @@map("missions")
}

model MissionAttempt {
  id           String   @id @default(cuid())
  userId       String
  missionId    String
  score        Int      @default(0)
  xpEarned     Int      @default(0)
  completed    Boolean  @default(false)
  architecture String   @default("{}")
  metrics      String   @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@map("mission_attempts")
}

/// LLD Phase submission — stores the user's class design, API contracts, and data schema
model LLDAttempt {
  id           String   @id @default(cuid())
  userId       String
  missionId    String
  /// User's class/entity design — free-form text or structured JSON
  classDesign  String   @default("")
  /// User's API endpoint contracts — e.g. "POST /messages → { chatId, content }"
  apiContracts String   @default("")
  /// User's data schema — table/collection definitions
  dataSchema   String   @default("")
  /// Computed score 0-100
  score        Int      @default(0)
  /// JSON array of feedback items
  feedback     String   @default("[]")
  /// XP earned from this LLD attempt
  xpEarned     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@map("lld_attempts")
}

model Achievement {
  id          String @id @default(cuid())
  slug        String @unique
  title       String
  description String
  icon        String
  xpBonus     Int    @default(0)

  userAchievements UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

model MissionRubric {
  id          String   @id @default(cuid())
  missionSlug String
  version     String
  items       String
  status      String   @default("approved")
  createdAt   DateTime @default(now())

  @@unique([missionSlug, version])
  @@map("mission_rubrics")
}
