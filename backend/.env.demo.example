# ─────────────────────────────────────────────────────────────────────────────
# Demo Seed Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to backend/.env.local (gitignored) and fill in real values.
# .env.local is loaded automatically by seed-demo.ts before .env.
#
# NEVER commit .env.local or any file containing real credentials.
# ─────────────────────────────────────────────────────────────────────────────

# Email address for the demo login account
DEMO_SEED_EMAIL=demo@your-domain.com

# Password for the demo login account (min 12 chars recommended)
DEMO_SEED_PASSWORD=change-me-before-running

# (Optional) Display username shown in the UI — defaults to SysQuestDemo
# DEMO_SEED_USERNAME=SysQuestDemo
