generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  passwordHash String
  xp           Int      @default(0)
  level        Int      @default(1)
  /// beginner | intermediate | advanced — set on onboarding, auto-upgrades on performance
  skillLevel   String   @default("beginner")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  missionAttempts   MissionAttempt[]
  achievements      UserAchievement[]
  lldAttempts       LLDAttempt[]
  interviewSessions InterviewSession[]

  @@map("users")
}

model Mission {
  id            String  @id @default(cuid())
  slug          String  @unique
  title         String
  difficulty    Int     @default(1)
  estimatedTime String
  xpReward      Int
  order         Int
  description   String
  scenario      String
  objectives    String  // JSON array
  requirements  String  // JSON object
  components    String  // JSON object
  feedbackData  String  // JSON object
  /// Learning path slug: foundations | async-queues | high-read | real-time | consistency | scale-streaming
  learningPath  String  @default("foundations")
  /// Skill level gate: beginner | intermediate | advanced
  skillLevel    String  @default("beginner")
  /// Whether the LLD phase is enabled for this mission
  lldEnabled    Boolean @default(false)
  /// JSON: LLDContent — classes, apiEndpoints, dataSchema, keyEntities
  lldContent    String?
  /// JSON: ReferenceSolution — components, connections, keyInsights, tradeoffs, antiPatterns
  referenceSolution String?

  missionAttempts   MissionAttempt[]
  lldAttempts       LLDAttempt[]
  interviewSessions InterviewSession[]

  @@map("missions")
}

model MissionAttempt {
  id           String   @id @default(cuid())
  userId       String
  missionId    String
  score        Int      @default(0)
  xpEarned     Int      @default(0)
  completed    Boolean  @default(false)
  architecture String   @default("{}") // JSON - saved architecture
  metrics      String   @default("{}") // JSON - simulation metrics
  /// True once the user has opened the Compare panel for this attempt
  comparisonViewed Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@map("mission_attempts")
}

/// LLD Phase submission — stores the user's class design, API contracts, and data schema
model LLDAttempt {
  id           String   @id @default(cuid())
  userId       String
  missionId    String
  /// User's class/entity design — free-form text or structured JSON
  classDesign  String   @default("")
  /// User's API endpoint contracts — e.g. "POST /messages → { chatId, content }"
  apiContracts String   @default("")
  /// User's data schema — table/collection definitions
  dataSchema   String   @default("")
  /// Computed score 0-100
  score        Int      @default(0)
  /// JSON array of feedback items
  feedback     String   @default("[]")
  /// XP earned from this LLD attempt
  xpEarned     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@map("lld_attempts")
}

/// Interview simulation session — timed 45-min FAANG-style system design session
model InterviewSession {
  id              String    @id @default(cuid())
  userId          String
  missionId       String
  /// active | completed | abandoned
  status          String    @default("active")
  /// Allowed duration in minutes (default 45)
  durationMinutes Int       @default(45)
  startedAt       DateTime  @default(now())
  submittedAt     DateTime?
  /// JSON: array of { questionId, askedAt, userAnswer }
  followupLog     String    @default("[]")
  /// JSON: RubricScores { correctness, depth, tradeoffs, apiDesign, timeManagement }
  rubricScores    String    @default("{}")
  /// Overall score 0-100 computed from rubric
  totalScore      Int       @default(0)
  /// XP awarded for this session
  xpEarned        Int       @default(0)
  /// Snapshot of the architecture submitted at end
  finalArchitecture String  @default("{}")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@map("interview_sessions")
}

model Achievement {
  id          String @id @default(cuid())
  slug        String @unique
  title       String
  description String
  icon        String
  xpBonus     Int    @default(0)

  userAchievements UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

// ── Living Rubrics (Phase 4) ────────────────────────────────────────────────────

/// One approved rubric per mission version. Generated by AI, stored as versioned JSON.
/// version = sha256(missionSlug + itemsJson) — content-addressed, never mutated.
model MissionRubric {
  id          String   @id @default(cuid())
  missionSlug String
  /// Content-addressed version hash: sha256(missionSlug + itemsJson)
  version     String
  /// JSON array of RubricItem objects
  items       String
  /// draft | approved | deprecated  — auto-approved on first generation for MVP
  status      String   @default("approved")
  createdAt   DateTime @default(now())

  @@unique([missionSlug, version])
  @@map("mission_rubrics")
}
