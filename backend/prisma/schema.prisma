generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  passwordHash String
  xp           Int      @default(0)
  level        Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  missionAttempts MissionAttempt[]
  achievements    UserAchievement[]

  @@map("users")
}

model Mission {
  id            String  @id @default(cuid())
  slug          String  @unique
  title         String
  difficulty    Int     @default(1)
  estimatedTime String
  xpReward      Int
  order         Int
  description   String
  scenario      String
  objectives    String  // JSON array
  requirements  String  // JSON object
  components    String  // JSON object
  feedbackData  String  // JSON object

  missionAttempts MissionAttempt[]

  @@map("missions")
}

model MissionAttempt {
  id           String   @id @default(cuid())
  userId       String
  missionId    String
  score        Int      @default(0)
  xpEarned     Int      @default(0)
  completed    Boolean  @default(false)
  architecture String   @default("{}") // JSON - saved architecture
  metrics      String   @default("{}") // JSON - simulation metrics
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@map("mission_attempts")
}

model Achievement {
  id          String @id @default(cuid())
  slug        String @unique
  title       String
  description String
  icon        String
  xpBonus     Int    @default(0)

  userAchievements UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

// ── Living Rubrics (Phase 4) ──────────────────────────────────────────

/// One approved rubric per mission version. Generated by AI, stored as versioned JSON.
/// version = sha256(missionSlug + itemsJson) — content-addressed, never mutated.
model MissionRubric {
  id          String   @id @default(cuid())
  missionSlug String
  /// Content-addressed version hash: sha256(missionSlug + itemsJson)
  version     String
  /// JSON array of RubricItem objects
  items       String
  /// draft | approved | deprecated  — auto-approved on first generation for MVP
  status      String   @default("approved")
  createdAt   DateTime @default(now())

  @@unique([missionSlug, version])
  @@map("mission_rubrics")
}
